{
  "name": "harness-prd-docs",
  "version": "0.1.0",
  "private": true,
  "description": "Docs site for the Agentic Harness Orchestration System PRD. Reads sibling /prd/ markdown and /diagrams/ mermaid files, renders them with MDX and client-side Mermaid.",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev --port 4567",
    "build": "next build",
    "start": "next start --port 4567",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "mermaid": "^11.4.1",
    "next": "^16.0.0",
    "next-mdx-remote": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "typescript": "^5.6.0"
  }
}
