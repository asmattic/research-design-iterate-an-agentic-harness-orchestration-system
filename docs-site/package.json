{
  "name": "harness-prd-docs",
  "version": "0.1.0",
  "private": true,
  "description": "Docs site for the Agentic Harness Orchestration System PRD. Reads sibling /prd/ markdown and /diagrams/ mermaid files, renders them with MDX and client-side Mermaid.",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev --port 4567",
    "build": "next build",
    "start": "next start --port 4567",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:js": "pnpm run typecheck && pnpm run build && node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.11.0",
    "mermaid": "^11.4.1",
    "next": "^16.0.0",
    "next-mdx-remote": "^5.0.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "shadcn": "^4.5.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.6.0"
  }
}
