# Cowork sandbox artifact: symlink to the live, session-scoped auto-memory
# directory. The target path only resolves inside a Cowork sandbox, so the
# link itself is not meaningful outside it. Committed snapshots live in
# memory/, refreshed via scripts/sync-memory.sh.
.auto-memory

# Sandbox-only: git bundle copy, and any aborted .git from FUSE weirdness.
*.bundle
.git-broken-*

